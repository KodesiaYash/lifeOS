# =============================================================================
# AI Life OS — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_NAME=ai-life-os
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# --- Database (PostgreSQL + pgvector) ---
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=lifeos
POSTGRES_DB=lifeos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lifeos:lifeos@localhost:5432/lifeos

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object Storage (MinIO / S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lifeos

# --- LLM / AI (LiteLLM - add keys for providers you want to use) ---
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (Gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (fast inference for Llama, Mixtral)
GROQ_API_KEY=gsk_your-groq-key-here

# Mistral
MISTRAL_API_KEY=your-mistral-key-here

# Azure OpenAI (optional)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview

# Default models (LiteLLM format)
# Examples: gpt-4o-mini, anthropic/claude-3-sonnet, gemini/gemini-pro, groq/llama3-70b-8192
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- Encryption ---
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# --- Scheduling ---
SCHEDULER_ENABLED=true
WORKER_ENABLED=true

# --- Telegram / Kernel Bots ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_API_BASE=https://api.telegram.org
DUTCH_TUTOR_BOT_ID=dutch_tutor
DUTCH_TUTOR_ENABLED=true
